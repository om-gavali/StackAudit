# AI Spend Audit - Server Configuration Template
# DO NOT commit the active .env file to version control.
# Copy this template to .env and fill in your private parameters.

# Server Configuration
PORT=5000
NODE_ENV=production

# Database Connection (MongoDB URL)
# Example: mongodb://127.0.0.1:27017/ai-spend-audit
MONGODB_URI=

# Authentication Settings
# Use high-entropy random characters for JWT secret
JWT_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Frontend Application Origin (CORS Whitelist Entry)
CLIENT_URL=http://localhost:5173

# SMTP Email Configuration (Nodemailer support)
# Optional: Leaves blank to automatically provision local Ethereal test inbox sandbox
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# OpenAI Integration Key
# Optional: Leaves blank to automatically activate safe fallback template summarizer
OPENAI_API_KEY=

# Google Gemini Integration (Primary AI provider)
# Get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
